      },
      "SourceReadCommand": {
        "type": "string",
        "defaultValue": "asdfa"
      },
      "ModelName": {
        "type": "string",
        "defaultValue": "framework"
      },
      "BatchExecution": {
        "type": "string",
        "defaultValue": "zcvzdad"
      },
      "param_workspace_id": {
        "type": "string"
      },
      "param_kusto_uri": {
        "type": "string"
      },
      "param_kqldatabase_id": {
        "type": "string"
      }
    },
    "variables": {
      "kql_command": {
        "type": "String"
      },
      "endDate": {
        "type": "String"
