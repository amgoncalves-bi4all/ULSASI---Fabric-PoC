          "connection": "b03b482e-90ea-4aeb-8a57-a51b153d27eb"
        }
      },
      {
        "name": "If current workspace is official",
        "type": "IfCondition",
        "dependsOn": [
          {
            "activity": "Get current Workspace",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "typeProperties": {
          "expression": {
            "value": "@if(startswith(activity('Get current Workspace').output.displayName,pipeline().parameters.param_ws_official_prefix), bool(1), bool(0))",
            "type": "Expression"
          },
          "ifFalseActivities": [
            {
              "name": "Get all Workspaces",
              "type": "WebActivity",
              "dependsOn": [],
              "policy": {
                "timeout": "0.12:00:00",
                "retry": 0,
                "retryIntervalInSeconds": 30,
                "secureOutput": false,
                "secureInput": false
              },
              "typeProperties": {
                "method": "GET",
                "headers": {},
                "relativeUrl": "/workspaces"
              },
              "externalReferences": {
                "connection": "b03b482e-90ea-4aeb-8a57-a51b153d27eb"
              }
            },
            {
              "name": "Set var_official_workspace_id",
              "type": "SetVariable",
              "dependsOn": [
                {
                  "activity": "Filter get official workspace ID",
                  "dependencyConditions": [
                    "Succeeded"
                  ]
                }
              ],
              "policy": {
                "secureOutput": false,
                "secureInput": false
              },
              "typeProperties": {
                "variableName": "var_official_workspace_id",
                "value": {
                  "value": "@activity('Filter get official workspace ID').output.value[0].id",
                  "type": "Expression"
                }
              }
            },
            {
              "name": "Filter get official workspace ID",
              "type": "Filter",
              "dependsOn": [
                {
                  "activity": "Get all Workspaces",
                  "dependencyConditions": [
                    "Succeeded"
                  ]
                }
              ],
              "typeProperties": {
                "items": {
                  "value": "@activity('Get all Workspaces').output.value",
                  "type": "Expression"
                },
                "condition": {
                  "value": "@equals(item().displayName, concat(pipeline().parameters.param_ws_official_prefix, '-dev'))",
                  "type": "Expression"
                }
              }
            }
          ],
          "ifTrueActivities": [
            {
              "name": "Set var_official_workspace_id - current",
              "type": "SetVariable",
              "dependsOn": [],
              "policy": {
                "secureOutput": false,
                "secureInput": false
              },
              "typeProperties": {
                "variableName": "var_official_workspace_id",
                "value": {
                  "value": "@activity('Get current Workspace').output.id",
                  "type": "Expression"
                }
              }
            },
            {
              "name": "Set var_is_current_ws_official",
              "type": "SetVariable",
              "dependsOn": [],
              "policy": {
                "secureOutput": false,
                "secureInput": false
              },
              "typeProperties": {
                "variableName": "var_is_current_ws_official",
                "value": true
              }
            }
          ]
        }
      },
